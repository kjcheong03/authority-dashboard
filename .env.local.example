# ── Required ──────────────────────────────────────────────────────────────
# TinyFish agentic browsing (live scrape + claim scan)
TINYFISH_API_KEY=
# OpenAI (claim classification, origin trace via web search, advisory draft)
OPENAI_API_KEY=

# ── Optional integrations (each degrades gracefully if unset) ───────────────

# Google Fact Check Tools API — corroborating published fact-checks per claim.
# Create a free API key in Google Cloud (enable "Fact Check Tools API"):
#   https://console.cloud.google.com/apis/library/factchecktools.googleapis.com
GOOGLE_FACTCHECK_API_KEY=

# GDELT via BigQuery — reliable, rate-limit-free coverage velocity + tone.
# Point this at a GCP service-account JSON key file with BigQuery access.
# Without it, the app falls back to the GDELT DOC 2.0 API automatically.
#   GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# data.gov.sg (NEA dengue clusters) needs NO key — it just works.
