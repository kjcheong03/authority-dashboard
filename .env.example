# Copy to .env.local and fill in.

# Required for live research, claim classification, advisory drafting, and translation.
OPENAI_API_KEY=

# Supabase project settings, used for research runs and published broadcasts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Google Fact Check Tools API key.
GOOGLE_FACTCHECK_API_KEY=

# Optional: GDELT BigQuery credentials.
# Use either inline service-account JSON plus a project id, or a local credentials file.
GCP_SA_KEY=
GOOGLE_CLOUD_PROJECT=
GCP_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
